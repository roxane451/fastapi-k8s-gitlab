# Copy as .env, then edit
# DO NOT commit .env to Git.

# Gateway service (API Gateway)
SECRET_KEY=replace_with_strong_secret
USERS_SERVICE_URL=http://users:8082
ORDERS_SERVICE_URL=http://orders:8081

# Users service
USERS_DATABASE_URL=sqlite:///users.db

# Orders service
ORDERS_DATABASE_URL=sqlite:///orders.db
